#!/bin/bash
# 月報データ取得スクリプト
# screenpipeから指定月の作業ログを取得し、AIアプリに送信

CACHE_DIR="$HOME/.cache/geppou"

# ヘルプ
if [ "$1" = "help" ] || [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
  cat <<'HELP'
geppou - 月報生成ツール

使い方:
  geppou              月報を作成（月選択 → データ取得 → AIアプリへ送信）
  geppou cache list   キャッシュ一覧を表示
  geppou cache clear  fzfで選択してキャッシュを削除
  geppou cache clear YYYY-MM  指定月のキャッシュを削除
  geppou cache clear --all    全キャッシュを削除
  geppou help         このヘルプを表示

概要:
  screenpipeの画面キャプチャ記録と~/Sites以下のGitコミット履歴から
  月報用のプロンプトを生成し、選択したAIアプリに送信します。
  同じ月のデータはキャッシュされ、再実行時に再利用されます。

キャッシュ:
  保存先: ~/.cache/geppou/
  再取得したい場合は cache clear で削除してから再実行してください。
HELP
  exit 0
fi

# キャッシュ管理サブコマンド
if [ "$1" = "cache" ]; then
  case "$2" in
    list|ls)
      if [ ! -d "$CACHE_DIR" ] || [ -z "$(ls "$CACHE_DIR" 2>/dev/null)" ]; then
        echo "キャッシュはありません"
        exit 0
      fi
      echo "キャッシュ一覧:"
      for f in "$CACHE_DIR"/*_screenpipe.txt; do
        [ -f "$f" ] || continue
        month=$(basename "$f" | sed 's/_screenpipe\.txt//')
        size_s=$(wc -c < "$f" | tr -d ' ')
        size_c=0
        [ -f "$CACHE_DIR/${month}_commits.txt" ] && size_c=$(wc -c < "$CACHE_DIR/${month}_commits.txt" | tr -d ' ')
        echo "  ${month}  screenpipe: ${size_s}B  commits: ${size_c}B"
      done
      ;;
    clear)
      if [ "$3" = "--all" ]; then
        rm -rf "$CACHE_DIR"
        echo "全キャッシュを削除しました"
      elif [ -n "$3" ]; then
        rm -f "$CACHE_DIR/${3}_screenpipe.txt" "$CACHE_DIR/${3}_commits.txt"
        echo "${3} のキャッシュを削除しました"
      else
        # fzfで選択
        if [ ! -d "$CACHE_DIR" ] || [ -z "$(ls "$CACHE_DIR"/*_screenpipe.txt 2>/dev/null)" ]; then
          echo "キャッシュはありません"
          exit 0
        fi
        MONTHS=$(for f in "$CACHE_DIR"/*_screenpipe.txt; do basename "$f" | sed 's/_screenpipe\.txt//'; done)
        SELECTED=$(echo "$MONTHS" | fzf --height 30% --reverse --header "削除するキャッシュを選択")
        if [ -n "$SELECTED" ]; then
          rm -f "$CACHE_DIR/${SELECTED}_screenpipe.txt" "$CACHE_DIR/${SELECTED}_commits.txt"
          echo "${SELECTED} のキャッシュを削除しました"
        else
          echo "キャンセルしました"
        fi
      fi
      ;;
    *)
      echo "使い方: geppou cache <list|clear> [--all|YYYY-MM]"
      echo ""
      echo "  list        キャッシュ一覧を表示"
      echo "  clear       fzfで選択して削除"
      echo "  clear YYYY-MM  指定月のキャッシュを削除"
      echo "  clear --all    全キャッシュを削除"
      ;;
  esac
  exit 0
fi

# 月選択メニューを生成（今月から6ヶ月分 + 自由入力）
generate_month_options() {
  for i in 0 1 2 3 4 5; do
    date -v-${i}m +"%Y年%m月"
  done
  echo "その他（自由入力）"
}

# 月を選択
echo "何月の月報を作成しますか？"
SELECTED=$(generate_month_options | fzf --height 40% --reverse --header "月を選択")

if [ -z "$SELECTED" ]; then
  echo "キャンセルしました"
  exit 0
fi

# 選択に応じて日付範囲を計算
if [ "$SELECTED" = "その他（自由入力）" ]; then
  echo -n "対象年月を入力してください (例: 2024-06): "
  read INPUT_MONTH
  if [ -z "$INPUT_MONTH" ]; then
    echo "キャンセルしました"
    exit 0
  fi
  # 入力値から日付範囲を計算
  START_DATE="${INPUT_MONTH}-01T00:00:00Z"
  # 翌月1日の前日 = 当月末日
  END_DATE=$(date -j -v+1m -v-1d -f "%Y-%m-%d" "${INPUT_MONTH}-01" "+%Y-%m-%dT23:59:59Z")
  CACHE_KEY="$INPUT_MONTH"
else
  # 選択された月から日付範囲を計算 (例: "2024年12月" -> "2024-12")
  YEAR_MONTH=$(echo "$SELECTED" | sed 's/年/-/; s/月//')
  START_DATE="${YEAR_MONTH}-01T00:00:00Z"
  END_DATE=$(date -j -v+1m -v-1d -f "%Y-%m-%d" "${YEAR_MONTH}-01" "+%Y-%m-%dT23:59:59Z")
  CACHE_KEY="$YEAR_MONTH"
fi

echo ""
echo "期間: $START_DATE 〜 $END_DATE"

# キャッシュディレクトリ作成
mkdir -p "$CACHE_DIR"

CACHE_SCREENPIPE="$CACHE_DIR/${CACHE_KEY}_screenpipe.txt"
CACHE_COMMITS="$CACHE_DIR/${CACHE_KEY}_commits.txt"

# screenpipeデータ取得（キャッシュあれば再利用）
if [ -f "$CACHE_SCREENPIPE" ]; then
  echo "screenpipeデータ: キャッシュを使用"
  LOG_DATA=$(cat "$CACHE_SCREENPIPE")
else
  echo "screenpipeからデータを取得中..."
  LOG_DATA=$(curl -s "http://localhost:3030/search?start_time=${START_DATE}&end_time=${END_DATE}&limit=500" \
    | jq -r '[.data[].content.text // empty] | join("\n")' 2>/dev/null \
    | head -c 15000)

  if [ -z "$LOG_DATA" ]; then
    echo "エラー: データを取得できませんでした。screenpipeが起動しているか確認してください。"
    exit 1
  fi
  echo "$LOG_DATA" > "$CACHE_SCREENPIPE"
  echo "screenpipeデータ: キャッシュに保存しました"
fi

# コミット履歴取得（キャッシュあれば再利用）
if [ -n "$INPUT_MONTH" ]; then
  GIT_SINCE="${INPUT_MONTH}-01"
  GIT_UNTIL=$(date -j -v+1m -f "%Y-%m-%d" "${INPUT_MONTH}-01" "+%Y-%m-%d")
else
  GIT_SINCE="${YEAR_MONTH}-01"
  GIT_UNTIL=$(date -j -v+1m -f "%Y-%m-%d" "${YEAR_MONTH}-01" "+%Y-%m-%d")
fi

if [ -f "$CACHE_COMMITS" ]; then
  echo "コミット履歴: キャッシュを使用"
  COMMIT_DATA=$(cat "$CACHE_COMMITS")
else
  echo "コミット履歴を取得中..."
  COMMIT_DATA=""
  for repo in ~/Sites/*/; do
    if [ -d "$repo/.git" ]; then
      commits=$(git -C "$repo" log --author="$(git -C "$repo" config user.name)" --since="$GIT_SINCE" --until="$GIT_UNTIL" --oneline 2>/dev/null)
      if [ -n "$commits" ]; then
        COMMIT_DATA="${COMMIT_DATA}=== $(basename "$repo") ===
$commits

"
      fi
    fi
  done
  echo "$COMMIT_DATA" > "$CACHE_COMMITS"
  echo "コミット履歴: キャッシュに保存しました"
fi

# プロンプトとデータを結合してクリップボードにコピー
COMMIT_SECTION=""
if [ -n "$COMMIT_DATA" ]; then
  COMMIT_SECTION="
---
【Gitコミット履歴】
$COMMIT_DATA"
fi

PROMPT="あなたは日本語で回答するアシスタントです。

以下は${SELECTED}の画面キャプチャから取得した作業記録と、Gitコミット履歴です。
この記録から、どのような案件・プロジェクトに取り組んでいたかを読み取り、月報として要約してください。

【出力形式】
必ず以下のフォーマットに従って出力すること。フォーマット外の文章・説明・前置き・まとめは一切不要。

各項目の意味（KPT法）:
  ○ = Keep：良かったこと。今後も継続していくこと。
  × = Problem：課題など。
  T = Try：今後の改善施策。

## 案件名A
- ○：良かったこと・今後も継続していくこと
- ○：良かったこと・今後も継続していくこと
- ×：課題など
- T：今後の改善施策

## 案件名B
- ○：良かったこと・今後も継続していくこと

## 案件名C
- ○：良かったこと・今後も継続していくこと
- ○：良かったこと・今後も継続していくこと
- T：今後の改善施策

【ルール】
- 案件/プロジェクトごとに必ずMarkdown見出し（## 案件名）で個別の見出しを立てること。「その他」「その他プロジェクト」「雑務」等のカテゴリでまとめることは禁止。作業が1件しかない案件でも個別の見出しにすること
- 各項目は必ず「- ○：」「- ×：」「- T：」のようにMarkdownリスト形式（ハイフン始まり）で記述すること
- ×やTは該当がなければ省略してよい（上記の案件名Bの例を参照）
- 見出しの案件名はシンプルにすること。「特設サイト」「公式サイト」「公式ウェブサイト」等の修飾は不要。ドメイン名がわかる場合は「案件名（example.com）」の形式にする
- 技術的な専門用語は避け、非エンジニアにも伝わる平易な表現を使うこと（例: 「APIエンドポイントの実装」→「データ連携機能の作成」、「CSSリファクタリング」→「画面デザインの整理」）
- 技術的なコマンドやコードの詳細は不要、作業の概要のみ
---
【画面キャプチャ記録】
$LOG_DATA
$COMMIT_SECTION"

echo "$PROMPT" | pbcopy

echo ""
echo "クリップボードにコピーしました！"

# AIアプリを選択
echo ""
echo "どのAIアプリを使いますか？"
AI_APP=$(printf "Gemini ⭐\nChatGPT\nClaude\nOllama\nコピーのみ" | fzf --height 20% --reverse --header "AIアプリを選択（⭐ = デフォルト）" | sed 's/ ⭐$//')

if [ -z "$AI_APP" ]; then
  echo "キャンセルしました（クリップボードにはコピー済み）"
  exit 0
fi

if [ "$AI_APP" = "コピーのみ" ]; then
  echo "クリップボードにコピー済みです。お好みのアプリに貼り付けてください。"
  exit 0
fi

echo "${AI_APP}を開いて自動入力します..."

if [ "$AI_APP" = "Gemini" ]; then
  open "https://gemini.google.com/app"
  sleep 3
  osascript <<APPLESCRIPT
tell application "System Events"
    keystroke "v" using command down
    delay 0.5
    keystroke return
end tell
APPLESCRIPT
else
  osascript <<APPLESCRIPT
tell application "$AI_APP"
    activate
end tell

delay 1

tell application "System Events"
    keystroke "v" using command down
    delay 0.5
    keystroke return
end tell
APPLESCRIPT
fi
