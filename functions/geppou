#!/bin/bash
# 月報データ取得スクリプト
# screenpipeから指定月の作業ログを取得し、Ollamaデスクトップ用にクリップボードへコピー

# 月選択メニューを生成（今月から6ヶ月分 + 自由入力）
generate_month_options() {
  for i in 0 1 2 3 4 5; do
    date -v-${i}m +"%Y年%m月"
  done
  echo "その他（自由入力）"
}

# 月を選択
echo "何月の月報を作成しますか？"
SELECTED=$(generate_month_options | fzf --height 40% --reverse --header "月を選択")

if [ -z "$SELECTED" ]; then
  echo "キャンセルしました"
  exit 0
fi

# 選択に応じて日付範囲を計算
if [ "$SELECTED" = "その他（自由入力）" ]; then
  echo -n "対象年月を入力してください (例: 2024-06): "
  read INPUT_MONTH
  if [ -z "$INPUT_MONTH" ]; then
    echo "キャンセルしました"
    exit 0
  fi
  # 入力値から日付範囲を計算
  START_DATE="${INPUT_MONTH}-01T00:00:00Z"
  # 翌月1日の前日 = 当月末日
  END_DATE=$(date -j -v+1m -v-1d -f "%Y-%m-%d" "${INPUT_MONTH}-01" "+%Y-%m-%dT23:59:59Z")
else
  # 選択された月から日付範囲を計算 (例: "2024年12月" -> "2024-12")
  YEAR_MONTH=$(echo "$SELECTED" | sed 's/年/-/; s/月//')
  START_DATE="${YEAR_MONTH}-01T00:00:00Z"
  END_DATE=$(date -j -v+1m -v-1d -f "%Y-%m-%d" "${YEAR_MONTH}-01" "+%Y-%m-%dT23:59:59Z")
fi

echo ""
echo "期間: $START_DATE 〜 $END_DATE"
echo "screenpipeからデータを取得中..."

# screenpipeからデータ取得
LOG_DATA=$(curl -s "http://localhost:3030/search?start_time=${START_DATE}&end_time=${END_DATE}&limit=500" \
  | jq -r '[.data[].content.text // empty] | join("\n")' 2>/dev/null \
  | head -c 15000)

if [ -z "$LOG_DATA" ]; then
  echo "エラー: データを取得できませんでした。screenpipeが起動しているか確認してください。"
  exit 1
fi

# ~/Sites以下のリポジトリからコミット履歴を取得
echo "コミット履歴を取得中..."

# 日付範囲をgit log用に変換（YEAR_MONTHまたはINPUT_MONTHを使用）
if [ -n "$INPUT_MONTH" ]; then
  GIT_SINCE="${INPUT_MONTH}-01"
  GIT_UNTIL=$(date -j -v+1m -f "%Y-%m-%d" "${INPUT_MONTH}-01" "+%Y-%m-%d")
else
  GIT_SINCE="${YEAR_MONTH}-01"
  GIT_UNTIL=$(date -j -v+1m -f "%Y-%m-%d" "${YEAR_MONTH}-01" "+%Y-%m-%d")
fi

COMMIT_DATA=""
for repo in ~/Sites/*/; do
  if [ -d "$repo/.git" ]; then
    commits=$(git -C "$repo" log --author="$(git -C "$repo" config user.name)" --since="$GIT_SINCE" --until="$GIT_UNTIL" --oneline 2>/dev/null)
    if [ -n "$commits" ]; then
      COMMIT_DATA="${COMMIT_DATA}=== $(basename "$repo") ===
$commits

"
    fi
  fi
done

# プロンプトとデータを結合してクリップボードにコピー
COMMIT_SECTION=""
if [ -n "$COMMIT_DATA" ]; then
  COMMIT_SECTION="
---
【Gitコミット履歴】
$COMMIT_DATA"
fi

PROMPT="あなたは日本語で回答するアシスタントです。

以下は${SELECTED}の画面キャプチャから取得した作業記録と、Gitコミット履歴です。
この記録から、どのような案件・プロジェクトに取り組んでいたかを読み取り、月報として要約してください。

【出力形式】
必ず以下のフォーマットに従って出力すること。フォーマット外の文章・説明・前置き・まとめは一切不要。

## 案件名A
○：完了した作業内容
○：完了した作業内容
×：できなかったこと・反省点
T：反省を踏まえて今後取り組むタスク

## 案件名B
○：完了した作業内容

## 案件名C
○：完了した作業内容
○：完了した作業内容
T：反省を踏まえて今後取り組むタスク

【ルール】
- 案件/プロジェクトごとに必ずMarkdown見出し（## 案件名）で個別の見出しを立てること。「その他」「その他プロジェクト」「雑務」等のカテゴリでまとめることは禁止。作業が1件しかない案件でも個別の見出しにすること
- ○×Tの記号で始まる箇条書きのみで記述すること
- ×やTは該当がなければ省略してよい（上記の案件名Bの例を参照）
- 見出しの案件名はシンプルにすること。「特設サイト」「公式サイト」「公式ウェブサイト」等の修飾は不要。ドメイン名がわかる場合は「案件名（example.com）」の形式にする
- 技術的な専門用語は避け、非エンジニアにも伝わる平易な表現を使うこと（例: 「APIエンドポイントの実装」→「データ連携機能の作成」、「CSSリファクタリング」→「画面デザインの整理」）
- 技術的なコマンドやコードの詳細は不要、作業の概要のみ
---
【画面キャプチャ記録】
$LOG_DATA
$COMMIT_SECTION"

echo "$PROMPT" | pbcopy

echo ""
echo "クリップボードにコピーしました！"

# AIアプリを選択
echo ""
echo "どのAIアプリを使いますか？"
AI_APP=$(printf "Gemini ⭐\nChatGPT\nClaude\nOllama\nコピーのみ" | fzf --height 20% --reverse --header "AIアプリを選択（⭐ = デフォルト）" | sed 's/ ⭐$//')

if [ -z "$AI_APP" ]; then
  echo "キャンセルしました（クリップボードにはコピー済み）"
  exit 0
fi

if [ "$AI_APP" = "コピーのみ" ]; then
  echo "クリップボードにコピー済みです。お好みのアプリに貼り付けてください。"
  exit 0
fi

echo "${AI_APP}を開いて自動入力します..."

if [ "$AI_APP" = "Gemini" ]; then
  open "https://gemini.google.com/app"
  sleep 3
  osascript <<APPLESCRIPT
tell application "System Events"
    keystroke "v" using command down
    delay 0.5
    keystroke return
end tell
APPLESCRIPT
else
  osascript <<APPLESCRIPT
tell application "$AI_APP"
    activate
end tell

delay 1

tell application "System Events"
    keystroke "v" using command down
    delay 0.5
    keystroke return
end tell
APPLESCRIPT
fi
